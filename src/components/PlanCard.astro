---
import type { PlanRow } from "../lib/schema";

interface Props {
  plan: PlanRow;
  compact?: boolean;
}

const { plan, compact = false } = Astro.props;
const symbol = plan.currency === "USD" ? "$" : "¥";
const isFree = plan.monthlyPrice === 0;
const isContactSales = plan.monthlyPrice === null;
---

<article class:list={["plan-card", { compact, free: isFree }]}>
  <div class="topline">
    <span>{plan.provider.name}</span>
    <strong>{isFree ? "免费方案" : "个人订阅"}</strong>
  </div>
  <h3>{plan.name}</h3>
  <div class="price">
    {
      isFree
        ? <strong>免费</strong>
        : isContactSales
          ? <strong class="contact">联系厂商</strong>
          : <><strong>{symbol}{plan.monthlyPrice}</strong><span>/ 月</span></>
    }
  </div>
  {
    plan.annualMonthlyEquivalent !== null && (
      <p class="annual">
        年付 {symbol}{plan.annualPrice}，折合 {symbol}{plan.annualMonthlyEquivalent}/月
      </p>
    )
  }
  <p class="usage">{plan.usageSummary}</p>
  <div class="best-for">
    <span>适合</span>
    <strong>{plan.bestFor}</strong>
  </div>
  {!compact && <ul>{plan.features.slice(0, 4).map((feature) => <li>{feature}</li>)}</ul>}
  <a href={plan.sourceUrl} target="_blank" rel="noopener noreferrer">
    查看官方套餐
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M14 5h5v5M10 14 19 5M19 14v5H5V5h5" />
    </svg>
  </a>
  <small>最近确认于 {plan.verifiedAt}</small>
</article>

<style>
  .plan-card {
    position: relative;
    display: flex;
    min-width: 0;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 22px;
    background: rgba(10, 18, 32, 0.8);
  }

  .plan-card::before {
    position: absolute;
    top: -1px;
    right: 22px;
    left: 22px;
    height: 2px;
    content: "";
    background: var(--cyan);
    opacity: 0.72;
  }

  .plan-card.free::before {
    background: var(--green);
  }

  .topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: var(--muted);
    font-size: 11px;
  }

  .topline span {
    font-family: "SFMono-Regular", Consolas, monospace;
    font-weight: 800;
  }

  .topline strong {
    color: var(--green);
  }

  h3 {
    margin: 22px 0 0;
    font-size: 20px;
  }

  .price {
    display: flex;
    align-items: baseline;
    gap: 7px;
    min-height: 49px;
    margin-top: 12px;
  }

  .price strong {
    color: var(--text);
    font-size: 34px;
    line-height: 1.3;
  }

  .free .price strong {
    color: var(--green);
  }

  .price .contact {
    font-size: 24px;
  }

  .price span,
  .annual,
  small {
    color: var(--muted);
    font-size: 11px;
  }

  .annual {
    min-height: 18px;
    margin: 0;
  }

  .usage {
    min-height: 48px;
    margin: 16px 0 0;
    color: var(--cyan);
    font-size: 13px;
    font-weight: 750;
    line-height: 1.65;
  }

  .best-for {
    display: grid;
    gap: 5px;
    border-top: 1px solid var(--line);
    margin-top: 17px;
    padding-top: 15px;
  }

  .best-for span {
    color: var(--muted);
    font-size: 10px;
  }

  .best-for strong {
    font-size: 12px;
    line-height: 1.6;
  }

  ul {
    margin: 15px 0 0;
    padding-left: 18px;
  }

  li {
    color: var(--muted);
    font-size: 12px;
    line-height: 1.8;
  }

  a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 40px;
    margin-top: 18px;
    border: 1px solid rgba(103, 232, 249, 0.45);
    border-radius: 6px;
    padding: 10px 14px;
    background: rgba(103, 232, 249, 0.08);
    color: var(--cyan);
    font-size: 12px;
    font-weight: 800;
  }

  a:hover {
    border-color: var(--cyan);
    background: var(--cyan);
    color: #031018;
  }

  svg {
    width: 15px;
    height: 15px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  small {
    align-self: center;
    margin-top: 9px;
  }
</style>
