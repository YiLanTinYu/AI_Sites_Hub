---
import type { PlanRow } from "../lib/schema";

interface Candidate {
  plan: PlanRow;
  uses: string[];
  quality: number;
  ease: number;
  reason: string;
}

interface Props {
  candidates: Candidate[];
}

const { candidates } = Astro.props;

const estimatedCny = (plan: PlanRow) => {
  const monthly = plan.monthlyPrice ?? plan.annualMonthlyEquivalent;
  if (monthly === null) return 99999;
  return plan.currency === "USD" ? monthly * 7 : monthly;
};

const priceLabel = (plan: PlanRow) => {
  if (plan.monthlyPrice === 0) return "免费";
  const symbol = plan.currency === "USD" ? "$" : "¥";
  if (plan.monthlyPrice !== null) return `${symbol}${plan.monthlyPrice}/月`;
  if (plan.annualMonthlyEquivalent !== null) {
    return `${symbol}${plan.annualMonthlyEquivalent}/月（年付）`;
  }
  return "联系厂商";
};
---

<section class="finder" aria-labelledby="finder-title">
  <div class="finder-head">
    <div>
      <span>30 秒选 AI</span>
      <h2 id="finder-title">找到适合你的产品</h2>
    </div>
    <i aria-hidden="true"></i>
  </div>

  <div class="finder-fields">
    <fieldset data-field="use">
      <legend>主要用来做什么？</legend>
      <div class="segments">
        <button type="button" data-value="chat" aria-pressed="true">日常问答</button>
        <button type="button" data-value="research" aria-pressed="false">搜索研究</button>
        <button type="button" data-value="coding" aria-pressed="false">编程开发</button>
        <button type="button" data-value="image" aria-pressed="false">图片生成</button>
        <button type="button" data-value="video" aria-pressed="false">视频生成</button>
        <button type="button" data-value="audio" aria-pressed="false">音乐音频</button>
        <button type="button" data-value="office" aria-pressed="false">写作办公</button>
      </div>
    </fieldset>

    <fieldset data-field="budget">
      <legend>每月预算多少？</legend>
      <div class="segments budget">
        <button type="button" data-value="0" aria-pressed="true">只看免费</button>
        <button type="button" data-value="70" aria-pressed="false">约 ¥70 内</button>
        <button type="button" data-value="150" aria-pressed="false">约 ¥150 内</button>
        <button type="button" data-value="unlimited" aria-pressed="false">预算不限</button>
      </div>
    </fieldset>

  </div>

  <div class="finder-footer">
    <p class="finder-tip" aria-live="polite">
      <strong>日常问答</strong>
      <span>聊天答疑、解释概念、生活建议和灵感整理。</span>
    </p>
    <button class="finder-submit" type="button">
      帮我选
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 12h14M13 6l6 6-6 6"></path>
      </svg>
    </button>
  </div>

  <div class="finder-results" aria-live="polite" hidden>
    <div class="result-heading">
      <strong data-result-title>更适合你的选择</strong>
      <button type="button" data-reset>重新选择</button>
    </div>
    <p class="result-note" data-result-note></p>
    <div class="result-list">
      {
        candidates.map(({ plan, uses, quality, ease, reason }) => (
          <a
            class="result"
            href={plan.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-id={plan.id}
            data-provider={plan.providerId}
            data-uses={uses.join(",")}
            data-price-cny={estimatedCny(plan)}
            data-quality={quality}
            data-ease={ease}
            hidden
          >
            <span class="result-rank"></span>
            <div>
              <small>{plan.provider.name}</small>
              <strong>{plan.name}</strong>
              <p>{reason}</p>
            </div>
            <b>{priceLabel(plan)}</b>
          </a>
        ))
      }
    </div>
    <p class="result-empty" hidden>
      暂时没有同时符合这些条件的产品，请放宽预算或选择“都可以”。
    </p>
    <a class="result-more" href="/plans/">继续比较全部订阅套餐</a>
  </div>
</section>

<script>
  const finder = document.querySelector<HTMLElement>(".finder");

  if (finder) {
    const selections: Record<string, string> = {
      use: "chat",
      budget: "0",
    };
    const useDescriptions: Record<string, { title: string; text: string }> = {
      chat: { title: "日常问答", text: "聊天答疑、解释概念、生活建议和灵感整理。" },
      research: { title: "搜索研究", text: "联网查资料、核对来源、市场调研和报告整理。" },
      coding: { title: "编程开发", text: "代码补全、排查错误、理解项目和开发自动化。" },
      image: { title: "图片生成", text: "制作插画、海报、商品图和视觉创意。" },
      video: { title: "视频生成", text: "生成短视频、动态画面、素材和辅助剪辑。" },
      audio: { title: "音乐音频", text: "创作歌曲、配乐、配音和自然语音。" },
      office: { title: "写作办公", text: "写作润色、文档总结、方案和办公内容整理。" },
    };
    const tipTitle = finder.querySelector<HTMLElement>(".finder-tip strong");
    const tipText = finder.querySelector<HTMLElement>(".finder-tip span");

    finder.querySelectorAll<HTMLFieldSetElement>("fieldset").forEach((field) => {
      field.querySelectorAll<HTMLButtonElement>("button[data-value]").forEach((button) => {
        button.addEventListener("click", () => {
          field.querySelectorAll<HTMLButtonElement>("button[data-value]").forEach((item) => {
            item.setAttribute("aria-pressed", String(item === button));
          });
          selections[field.dataset.field ?? ""] = button.dataset.value ?? "";
          if (field.dataset.field === "use") {
            const description = useDescriptions[button.dataset.value ?? ""];
            if (description && tipTitle && tipText) {
              tipTitle.textContent = description.title;
              tipText.textContent = description.text;
            }
          }
        });
      });
    });

    const fields = finder.querySelector<HTMLElement>(".finder-fields");
    const footer = finder.querySelector<HTMLElement>(".finder-footer");
    const submit = finder.querySelector<HTMLButtonElement>(".finder-submit");
    const results = finder.querySelector<HTMLElement>(".finder-results");
    const resultTitle = finder.querySelector<HTMLElement>("[data-result-title]");
    const resultNote = finder.querySelector<HTMLElement>("[data-result-note]");
    const empty = finder.querySelector<HTMLElement>(".result-empty");
    const resultList = finder.querySelector<HTMLElement>(".result-list");
    const cards = [...finder.querySelectorAll<HTMLElement>(".result")];

    submit?.addEventListener("click", () => {
      const budget = selections.budget === "unlimited" ? Number.POSITIVE_INFINITY : Number(selections.budget);
      const metrics = (card: HTMLElement) => {
        const quality = Number(card.dataset.quality);
        const ease = Number(card.dataset.ease);
        const price = Number(card.dataset.priceCny);
        return { quality, ease, price };
      };
      const eligible = cards.filter((card) => {
        const uses = card.dataset.uses?.split(",") ?? [];
        return uses.includes(selections.use) && metrics(card).price <= budget;
      });
      const byProvider = new Map<string, HTMLElement[]>();
      eligible.forEach((card) => {
        const provider = card.dataset.provider ?? "";
        byProvider.set(provider, [...(byProvider.get(provider) ?? []), card]);
      });

      const planCeiling = Number.isFinite(budget) ? budget : 150;
      const providerChoices = [...byProvider.values()].map((providerCards) => {
        const mainstream = providerCards.filter((card) => metrics(card).price <= planCeiling);
        return [...(mainstream.length > 0 ? mainstream : providerCards)]
          .sort((a, b) => metrics(b).price - metrics(a).price)[0];
      });
      const freeChoices = [...byProvider.values()]
        .map((providerCards) => providerCards.find((card) => metrics(card).price === 0))
        .filter((card): card is HTMLElement => card !== undefined);
      const chosenProviders = new Set<string>();
      const recommendations: { card: HTMLElement; role: string }[] = [];
      const take = (
        choices: HTMLElement[],
        role: string,
        score: (card: HTMLElement) => number,
      ) => {
        const card = [...choices]
          .filter((item) => !chosenProviders.has(item.dataset.provider ?? ""))
          .sort((a, b) => score(b) - score(a))[0];
        if (!card) return;
        chosenProviders.add(card.dataset.provider ?? "");
        recommendations.push({ card, role });
      };

      take(
        providerChoices,
        "综合首选",
        (card) => metrics(card).quality * 10 + metrics(card).ease * 3 - metrics(card).price * 0.02,
      );
      take(
        freeChoices,
        "免费省钱",
        (card) => metrics(card).quality * 8 + metrics(card).ease * 4,
      );
      if (recommendations.length < 2) {
        take(
          providerChoices,
          "价格更低",
          (card) => 1000 - metrics(card).price + metrics(card).quality,
        );
      }
      take(
        providerChoices,
        "能力更强",
        (card) => metrics(card).quality * 12 + metrics(card).ease - metrics(card).price * 0.005,
      );
      if (recommendations.length < 3) {
        take(
          providerChoices,
          "更多选择",
          (card) => metrics(card).quality * 8 + metrics(card).ease * 3,
        );
      }

      cards.forEach((card) => {
        card.hidden = true;
        card.querySelector(".result-rank")?.replaceChildren();
      });
      recommendations.forEach(({ card, role }) => {
        card.hidden = false;
        card.querySelector(".result-rank")?.replaceChildren(role);
        resultList?.append(card);
      });
      if (resultTitle) {
        resultTitle.textContent =
          recommendations.length > 0
            ? `为你挑出的 ${recommendations.length} 个不同产品`
            : "没有找到匹配产品";
      }
      if (resultNote) {
        resultNote.textContent =
          recommendations.length < 3
            ? `当前收录中只有 ${recommendations.length} 家不同厂商符合条件，不用同一家不同套餐凑数。`
            : "三个位置分别侧重综合体验、免费省钱和能力表现，每家厂商最多出现一次。";
      }
      if (empty) empty.hidden = recommendations.length > 0;
      if (fields) fields.hidden = true;
      if (footer) footer.hidden = true;
      if (results) results.hidden = false;
    });

    finder.querySelector<HTMLButtonElement>("[data-reset]")?.addEventListener("click", () => {
      if (results) results.hidden = true;
      if (fields) fields.hidden = false;
      if (footer) footer.hidden = false;
    });
  }
</script>

<style>
  .finder {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(103, 232, 249, 0.58);
    border-radius: 8px;
    padding: 26px;
    background: rgba(10, 20, 36, 0.94);
    box-shadow: 0 20px 55px rgba(0, 0, 0, 0.34), inset 0 0 70px rgba(103, 232, 249, 0.045);
  }

  .finder::before {
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, var(--cyan), var(--green), #facc15);
    content: "";
  }

  .finder-head,
  .result-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .finder-head {
    border-bottom: 1px solid var(--line);
    padding-bottom: 18px;
  }

  .finder-head span {
    color: var(--cyan);
    font-size: 26px;
    font-weight: 900;
    line-height: 1.2;
  }

  .finder-head h2 {
    margin: 7px 0 0;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.4;
  }

  .finder-head i {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 12px rgba(134, 239, 172, 0.65);
  }

  .finder-fields {
    display: grid;
    gap: 18px;
    padding-top: 20px;
  }

  fieldset {
    min-width: 0;
    margin: 0;
    border: 0;
    padding: 0;
  }

  legend {
    margin-bottom: 9px;
    color: #d9e6f5;
    font-size: 15px;
    font-weight: 800;
  }

  .segments {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 8px;
  }

  .segments.budget {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .segments button {
    min-height: 46px;
    border: 1px solid rgba(148, 163, 184, 0.3);
    border-radius: 5px;
    padding: 7px 6px;
    background: #07111f;
    color: #cbd7e7;
    font: inherit;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
  }

  .segments button:hover {
    border-color: rgba(103, 232, 249, 0.48);
    color: var(--text);
  }

  .segments button[aria-pressed="true"] {
    border-color: var(--cyan);
    background: var(--cyan);
    color: #031018;
    font-weight: 900;
    box-shadow: 0 0 22px rgba(103, 232, 249, 0.2);
  }

  .finder-footer {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 28px;
    margin-top: 18px;
  }

  .finder-footer[hidden] {
    display: none;
  }

  .finder-tip {
    min-width: 0;
    margin: 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.6;
  }

  .finder-tip strong {
    display: block;
    margin-bottom: 2px;
    color: var(--text);
    font-size: 14px;
  }

  .finder-submit {
    display: flex;
    width: 180px;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 0;
    border: 0;
    border-radius: 6px;
    background: var(--cyan);
    color: #031018;
    font: inherit;
    font-size: 15px;
    font-weight: 900;
    cursor: pointer;
  }

  .finder-submit:hover {
    background: #a5f3fc;
  }

  .finder-submit svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .finder-results {
    padding-top: 18px;
  }

  .result-heading strong {
    font-size: 15px;
  }

  .result-heading button {
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--cyan);
    font: inherit;
    font-size: 13px;
    cursor: pointer;
  }

  .result-note {
    margin: 7px 0 0;
    color: var(--muted);
    font-size: 12px;
    line-height: 1.6;
  }

  .result-list {
    margin-top: 14px;
    border-block: 1px solid var(--line);
  }

  .result {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--line);
    padding: 15px 4px;
  }

  .result[hidden] {
    display: none;
  }

  .result:last-child {
    border-bottom: 0;
  }

  .result:hover strong {
    color: var(--cyan);
  }

  .result-rank {
    color: var(--cyan);
    font: 800 11px "SFMono-Regular", Consolas, monospace;
  }

  .result small {
    display: block;
    color: var(--muted);
    font-size: 11px;
  }

  .result strong {
    display: block;
    margin-top: 2px;
    font-size: 15px;
  }

  .result p {
    margin: 5px 0 0;
    color: var(--muted);
    font-size: 12px;
    line-height: 1.5;
  }

  .result b {
    color: var(--green);
    font-size: 13px;
    white-space: nowrap;
  }

  .result-more {
    display: inline-block;
    margin-top: 16px;
    color: var(--cyan);
    font-size: 13px;
    font-weight: 800;
  }

  .result-empty {
    margin: 0;
    padding: 24px 4px;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    font-size: 13px;
    line-height: 1.7;
  }

  @media (max-width: 520px) {
    .finder {
      padding: 20px 14px;
    }

    .finder-head h2 {
      font-size: 16px;
    }

    .finder-head span {
      font-size: 22px;
    }

    legend {
      font-size: 14px;
    }

    .segments {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .segments.budget {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .segments button {
      min-height: 46px;
      font-size: 13px;
    }

    .finder-submit {
      width: 100%;
    }

    .finder-footer {
      align-items: stretch;
      flex-direction: column;
      gap: 14px;
    }

    .result {
      grid-template-columns: 68px minmax(0, 1fr);
    }

    .result b {
      grid-column: 2;
    }
  }
</style>
