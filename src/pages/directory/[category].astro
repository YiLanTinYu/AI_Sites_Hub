---
import DirectoryCard from "../../components/DirectoryCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { directoryCategories, directoryItemsFor } from "../../lib/data";
import type { DirectoryCategory, DirectoryItem } from "../../lib/schema";

export function getStaticPaths() {
  return directoryCategories.map((category) => ({
    params: { category: category.id },
    props: {
      category,
      items: directoryItemsFor(category.id),
    },
  }));
}

interface Props {
  category: DirectoryCategory;
  items: DirectoryItem[];
}

const { category, items } = Astro.props;
---

<BaseLayout
  title={`${category.name} | 惠选AI`}
  description={`${category.description}，共收录 ${items.length} 个主流 AI 产品入口。`}
>
  <section class="page-head shell">
    <a href="/#directory">返回产品导航</a>
    <p>FULL PRODUCT DIRECTORY</p>
    <h1>{category.name}</h1>
    <div>
      <span>{category.description}</span>
      <strong>{items.length} 个入口</strong>
    </div>
  </section>
  <section class="shell directory-grid" aria-label={`${category.name}完整列表`}>
    {items.map((item) => <DirectoryCard item={item} />)}
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: 62px 34px;
  }

  .page-head > a {
    display: inline-block;
    margin-bottom: 30px;
    color: var(--cyan);
    font-size: 12px;
    font-weight: 800;
  }

  .page-head > p {
    margin: 0 0 12px;
    color: var(--cyan);
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 11px;
    font-weight: 800;
  }

  h1 {
    margin: 0;
    font-size: 44px;
  }

  .page-head div {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 30px;
    margin-top: 15px;
  }

  .page-head div span {
    max-width: 820px;
    color: var(--muted);
    line-height: 1.7;
  }

  .page-head strong {
    flex: 0 0 auto;
    color: var(--cyan);
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 12px;
  }

  .directory-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    padding-bottom: 90px;
  }

  @media (max-width: 820px) {
    .directory-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    h1 {
      font-size: 36px;
    }

    .page-head div {
      flex-direction: column;
      gap: 12px;
    }

    .directory-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
