---
import PlanCard from "../../components/PlanCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { planRows } from "../../lib/data";

const providerOrder = new Map(
  [
    "openai",
    "anthropic",
    "google",
    "perplexity",
    "github",
    "cursor",
    "midjourney",
    "runway",
    "suno",
    "elevenlabs",
    "deepseek",
    "moonshot",
    "zhipu",
    "baidu-comate",
  ].map((id, index) => [id, index]),
);
const rows = [...planRows].sort(
  (a, b) =>
    (providerOrder.get(a.providerId) ?? Number.POSITIVE_INFINITY) -
      (providerOrder.get(b.providerId) ?? Number.POSITIVE_INFINITY) ||
    (a.monthlyPrice ?? Number.POSITIVE_INFINITY) -
      (b.monthlyPrice ?? Number.POSITIVE_INFINITY),
);
const providerCount = new Set(rows.map((row) => row.providerId)).size;
const globalRows = rows.filter((row) => row.provider.region === "global");
const chinaRows = rows.filter((row) => row.provider.region === "china");
---

<BaseLayout
  title="AI 订阅套餐对比 | 惠选AI"
  description="比较 ChatGPT、Claude、Gemini 等主流 AI 产品的免费方案、个人月费、年付折算、使用额度和适用人群。"
>
  <section class="page-head shell">
    <p>AI SUBSCRIPTION PLANS</p>
    <h1>AI 订阅套餐</h1>
    <div class="summary">
      <span>{rows.length} 个个人套餐</span>
      <span>{providerCount} 家主流产品</span>
      <span>{globalRows.length} 个国外套餐 · {chinaRows.length} 个国内套餐</span>
    </div>
    <div class="plain-note">
      <strong>额度怎么看？</strong>
      <span>多数个人套餐不会承诺固定 Token 数，而是按消息、功能和系统负载动态调整。这里按厂商公开方式展示，不虚构固定额度。</span>
    </div>
  </section>

  <nav class="region-filter shell" aria-label="按地区筛选套餐">
    <a href="/plans/" data-region-filter="all" aria-current="page">
      全部
      <span>{rows.length}</span>
    </a>
    <a href="/plans/?region=china" data-region-filter="china">
      国内套餐
      <span>{chinaRows.length}</span>
    </a>
    <a href="/plans/?region=global" data-region-filter="global">
      国外套餐
      <span>{globalRows.length}</span>
    </a>
  </nav>

  <section class="shell plan-section" data-plan-sections>
    <section class="region-section" data-plan-region="global" aria-labelledby="global-plans">
      <div class="region-heading">
        <div>
          <p>GLOBAL PRODUCTS</p>
          <h2 id="global-plans">国外主流 AI 产品</h2>
        </div>
        <span>{globalRows.length} 个套餐</span>
      </div>
      <div class="plan-grid">
        {globalRows.map((plan) => <PlanCard plan={plan} />)}
      </div>
    </section>

    <section class="region-section" data-plan-region="china" aria-labelledby="china-plans">
      <div class="region-heading">
        <div>
          <p>CHINA PRODUCTS</p>
          <h2 id="china-plans">国内主流 AI 产品</h2>
        </div>
        <span>{chinaRows.length} 个套餐</span>
      </div>
      <div class="plan-grid">
        {chinaRows.map((plan) => <PlanCard plan={plan} />)}
      </div>
    </section>
    <p class="method-note">
      页面价格以美元区官网公开信息为主，不同地区的税费、币种、试用活动及功能可能不同。个人订阅通常不包含开发接口（API）额度，程序调用成本请查看
      <a href="/models/">开发者 API 价格</a>。
    </p>
  </section>

  <script>
    const filters = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-region-filter]"));
    const planSections = Array.from(document.querySelectorAll<HTMLElement>("[data-plan-region]"));
    const validRegions = new Set(["all", "china", "global"]);

    function applyRegion(region: string) {
      const activeRegion = validRegions.has(region) ? region : "all";
      planSections.forEach((section) => {
        section.hidden = activeRegion !== "all" && section.dataset.planRegion !== activeRegion;
      });
      filters.forEach((filter) => {
        if (filter.dataset.regionFilter === activeRegion) {
          filter.setAttribute("aria-current", "page");
        } else {
          filter.removeAttribute("aria-current");
        }
      });
    }

    function regionFromUrl() {
      return new URL(window.location.href).searchParams.get("region") ?? "all";
    }

    applyRegion(regionFromUrl());

    filters.forEach((filter) => {
      filter.addEventListener("click", (event) => {
        event.preventDefault();
        const region = filter.dataset.regionFilter ?? "all";
        const url = new URL(window.location.href);
        if (region === "all") {
          url.searchParams.delete("region");
        } else {
          url.searchParams.set("region", region);
        }
        window.history.pushState({}, "", url);
        applyRegion(region);
      });
    });

    window.addEventListener("popstate", () => applyRegion(regionFromUrl()));
  </script>
</BaseLayout>

<style>
  .page-head {
    padding-block: 76px 34px;
  }

  .page-head > p {
    margin: 0 0 13px;
    color: var(--cyan);
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 12px;
    font-weight: 800;
  }

  h1 {
    margin: 0;
    font-size: 46px;
  }

  .summary {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 22px;
    margin-top: 20px;
    color: var(--muted);
    font-size: 13px;
  }

  .plain-note {
    display: flex;
    gap: 10px;
    border-left: 2px solid var(--cyan);
    margin-top: 20px;
    padding: 10px 13px;
    background: rgba(103, 232, 249, 0.055);
  }

  .plain-note strong {
    flex: 0 0 auto;
    font-size: 11px;
  }

  .plain-note span {
    color: var(--muted);
    font-size: 11px;
    line-height: 1.6;
  }

  .plan-section {
    padding-bottom: 90px;
  }

  .region-filter {
    position: sticky;
    top: 70px;
    z-index: 10;
    display: flex;
    gap: 2px;
    border-block: 1px solid var(--line);
    padding-block: 10px;
    background: rgba(5, 7, 13, 0.9);
    backdrop-filter: blur(18px);
  }

  .region-filter a {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    gap: 8px;
    border: 1px solid transparent;
    padding: 0 14px;
    color: var(--muted);
    font-size: 12px;
    font-weight: 750;
  }

  .region-filter a:hover {
    color: var(--text);
  }

  .region-filter a[aria-current="page"] {
    border-color: rgba(103, 232, 249, 0.32);
    background: rgba(103, 232, 249, 0.09);
    color: var(--cyan);
  }

  .region-filter span {
    color: inherit;
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 10px;
  }

  .plan-section {
    padding-top: 30px;
  }

  .region-section + .region-section {
    margin-top: 58px;
  }

  .region-section[hidden] + .region-section {
    margin-top: 0;
  }

  .region-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 20px;
    padding-bottom: 17px;
  }

  .region-heading p {
    margin: 0 0 9px;
    color: var(--cyan);
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 11px;
    font-weight: 800;
  }

  .region-heading h2 {
    margin: 0;
    font-size: 26px;
  }

  .region-heading > span {
    color: var(--muted);
    font-size: 12px;
  }

  .plan-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .method-note {
    max-width: 900px;
    margin: 20px 2px 0;
    color: var(--muted);
    font-size: 11px;
    line-height: 1.7;
  }

  .method-note a {
    color: var(--cyan);
    font-weight: 750;
  }

  @media (max-width: 900px) {
    .plan-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .page-head {
      padding-top: 52px;
    }

    h1 {
      font-size: 36px;
    }

    .plain-note {
      display: grid;
    }

    .region-filter {
      width: 100%;
      overflow-x: auto;
      padding-inline: 18px;
    }

    .region-filter a {
      flex: 0 0 auto;
    }

    .region-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }

    .plan-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
