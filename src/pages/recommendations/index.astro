---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  estimatedMonthlyCny,
  productRecommendationCandidates,
  productScenarios,
} from "../../lib/product-recommendations";

const priceLabel = (currency: "USD" | "CNY", price: number | null, annual: number | null) => {
  const value = price ?? annual;
  if (value === 0) return "免费";
  if (value === null) return "联系厂商";
  return `${currency === "USD" ? "$" : "¥"}${value}/月${price === null ? "（年付）" : ""}`;
};
---

<BaseLayout
  title="AI 产品场景推荐 | 惠选AI"
  description="按实际用途和每月预算继续比较适合你的 AI 产品、订阅套餐与替代选择。"
>
  <section class="page-head shell">
    <p>PRODUCT RECOMMENDATIONS</p>
    <h1>按场景继续挑选</h1>
    <span>从首页带入用途和预算，查看更多不同厂商的合适套餐。每家厂商只展示一个主流选择。</span>
  </section>

  <section class="recommend-tool shell" aria-labelledby="recommend-heading">
    <div class="tool-head">
      <div>
        <p>继续调整条件</p>
        <h2 id="recommend-heading">找到更适合你的产品</h2>
      </div>
      <a href="/models/scenarios/">查看开发者 API 场景评分</a>
    </div>

    <fieldset>
      <legend>主要用来做什么？</legend>
      <div class="segments scenes">
        {Object.entries(productScenarios).map(([id, scenario]) => (
          <button type="button" data-scene={id}>{scenario.name}</button>
        ))}
      </div>
    </fieldset>

    <fieldset>
      <legend>每月预算多少？</legend>
      <div class="segments budgets">
        <button type="button" data-budget="0">只看免费</button>
        <button type="button" data-budget="70">约 ¥70 内</button>
        <button type="button" data-budget="150">约 ¥150 内</button>
        <button type="button" data-budget="unlimited">预算不限</button>
      </div>
    </fieldset>

    <div class="result-summary" aria-live="polite">
      <strong data-result-title></strong>
      <span data-result-note></span>
    </div>

    <div class="product-grid">
      {productRecommendationCandidates.map(({ plan, uses, quality, ease, reason }) => (
        <a
          class="product-rec"
          href={plan.sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-provider={plan.providerId}
          data-uses={uses.join(",")}
          data-price-cny={estimatedMonthlyCny(plan.currency, plan.monthlyPrice, plan.annualMonthlyEquivalent)}
          data-quality={quality}
          data-ease={ease}
          hidden
        >
          <div>
            <span>{plan.provider.name}</span>
            <b>{priceLabel(plan.currency, plan.monthlyPrice, plan.annualMonthlyEquivalent)}</b>
          </div>
          <h3>{plan.name}</h3>
          <p>{reason}</p>
          <small>查看官方套餐 →</small>
        </a>
      ))}
    </div>
    <div class="empty" hidden>当前收录中没有同时符合用途和预算的产品，请放宽预算后再试。</div>
  </section>
</BaseLayout>

<script>
  const tool = document.querySelector<HTMLElement>(".recommend-tool");
  if (tool) {
    const validScenes = ["chat", "research", "coding", "image", "video", "audio", "office"];
    const validBudgets = ["0", "70", "150", "unlimited"];
    const params = new URLSearchParams(window.location.search);
    let scene = validScenes.includes(params.get("scenario") ?? "") ? params.get("scenario")! : "chat";
    let budgetValue = validBudgets.includes(params.get("budget") ?? "") ? params.get("budget")! : "0";
    const cards = [...tool.querySelectorAll<HTMLElement>(".product-rec")];
    const title = tool.querySelector<HTMLElement>("[data-result-title]");
    const note = tool.querySelector<HTMLElement>("[data-result-note]");
    const empty = tool.querySelector<HTMLElement>(".empty");

    const metrics = (card: HTMLElement) => ({
      price: Number(card.dataset.priceCny),
      quality: Number(card.dataset.quality),
      ease: Number(card.dataset.ease),
    });

    const render = () => {
      const budget = budgetValue === "unlimited" ? Number.POSITIVE_INFINITY : Number(budgetValue);
      tool.querySelectorAll<HTMLButtonElement>("[data-scene]").forEach((button) => {
        button.setAttribute("aria-pressed", String(button.dataset.scene === scene));
      });
      tool.querySelectorAll<HTMLButtonElement>("[data-budget]").forEach((button) => {
        button.setAttribute("aria-pressed", String(button.dataset.budget === budgetValue));
      });

      const eligible = cards.filter((card) => {
        const uses = card.dataset.uses?.split(",") ?? [];
        return uses.includes(scene) && metrics(card).price <= budget;
      });
      const byProvider = new Map<string, HTMLElement[]>();
      eligible.forEach((card) => {
        const provider = card.dataset.provider ?? "";
        byProvider.set(provider, [...(byProvider.get(provider) ?? []), card]);
      });
      const ceiling = Number.isFinite(budget) ? budget : 150;
      const selected = [...byProvider.values()]
        .map((providerCards) => {
          const mainstream = providerCards.filter((card) => metrics(card).price <= ceiling);
          return [...(mainstream.length > 0 ? mainstream : providerCards)]
            .sort((a, b) => metrics(b).price - metrics(a).price)[0];
        })
        .sort(
          (a, b) =>
            metrics(b).quality * 10 +
            metrics(b).ease * 3 -
            metrics(b).price * 0.02 -
            (metrics(a).quality * 10 + metrics(a).ease * 3 - metrics(a).price * 0.02),
        )
        .slice(0, 8);

      cards.forEach((card) => (card.hidden = true));
      selected.forEach((card) => {
        card.hidden = false;
        tool.querySelector(".product-grid")?.append(card);
      });
      if (title) title.textContent = `${selected.length} 家不同厂商符合条件`;
      if (note) note.textContent = selected.length < 3 ? "候选较少时不会用同一家不同套餐凑数。" : "已按场景适配、易用程度和预算综合排序。";
      if (empty) empty.hidden = selected.length > 0;

      const next = new URL(window.location.href);
      next.searchParams.set("scenario", scene);
      next.searchParams.set("budget", budgetValue);
      history.replaceState(null, "", next);
    };

    tool.querySelectorAll<HTMLButtonElement>("[data-scene]").forEach((button) => {
      button.addEventListener("click", () => {
        scene = button.dataset.scene ?? "chat";
        render();
      });
    });
    tool.querySelectorAll<HTMLButtonElement>("[data-budget]").forEach((button) => {
      button.addEventListener("click", () => {
        budgetValue = button.dataset.budget ?? "0";
        render();
      });
    });
    render();
  }
</script>

<style>
  .page-head { padding-block: 68px 36px; }
  .page-head > p, .tool-head p { margin: 0 0 10px; color: var(--cyan); font: 800 11px "SFMono-Regular", Consolas, monospace; }
  h1 { margin: 0; font-size: 44px; }
  .page-head > span { display: block; max-width: 780px; margin-top: 15px; color: var(--muted); line-height: 1.7; }
  .recommend-tool { padding-bottom: 90px; }
  .tool-head { display: flex; align-items: end; justify-content: space-between; gap: 24px; border-top: 1px solid var(--line); padding-top: 28px; }
  .tool-head h2 { margin: 0; font-size: 25px; }
  .tool-head a { color: var(--cyan); font-size: 13px; font-weight: 800; }
  fieldset { margin: 25px 0 0; border: 0; padding: 0; }
  legend { margin-bottom: 10px; color: var(--text); font-size: 14px; font-weight: 800; }
  .segments { display: grid; gap: 8px; }
  .scenes { grid-template-columns: repeat(7, minmax(0, 1fr)); }
  .budgets { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .segments button { min-height: 46px; border: 1px solid var(--line); border-radius: 5px; background: #07111f; color: #cbd7e7; font: inherit; font-size: 13px; font-weight: 700; cursor: pointer; }
  .segments button[aria-pressed="true"] { border-color: var(--cyan); background: var(--cyan); color: #031018; font-weight: 900; }
  .result-summary { display: flex; align-items: baseline; justify-content: space-between; gap: 18px; margin-top: 32px; border-bottom: 1px solid var(--line); padding-bottom: 12px; }
  .result-summary strong { font-size: 18px; }
  .result-summary span { color: var(--muted); font-size: 12px; }
  .product-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-top: 18px; }
  .product-rec { min-height: 190px; border: 1px solid var(--line); border-radius: 8px; padding: 19px; background: rgba(10,18,32,.78); }
  .product-rec[hidden] { display: none; }
  .product-rec:hover { border-color: rgba(103,232,249,.55); }
  .product-rec > div { display: flex; justify-content: space-between; gap: 12px; }
  .product-rec span { color: var(--muted); font-size: 11px; }
  .product-rec b { color: var(--green); font-size: 13px; }
  .product-rec h3 { margin: 24px 0 0; font-size: 19px; }
  .product-rec p { margin: 9px 0 0; color: var(--muted); font-size: 13px; line-height: 1.6; }
  .product-rec small { display: block; margin-top: 18px; color: var(--cyan); font-size: 12px; font-weight: 800; }
  .empty { margin-top: 18px; border: 1px solid var(--line); padding: 34px; color: var(--muted); text-align: center; }
  @media (max-width: 900px) { .scenes { grid-template-columns: repeat(4, 1fr); } .product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) {
    .page-head { padding-block: 52px 28px; }
    h1 { font-size: 35px; }
    .tool-head, .result-summary { align-items: flex-start; flex-direction: column; }
    .scenes { grid-template-columns: repeat(2, 1fr); }
    .budgets { grid-template-columns: repeat(2, 1fr); }
    .product-grid { grid-template-columns: 1fr; }
  }
</style>
