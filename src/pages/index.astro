---
import DirectoryCard from "../components/DirectoryCard.astro";
import DealCard from "../components/DealCard.astro";
import AiFinder from "../components/AiFinder.astro";
import PlanCard from "../components/PlanCard.astro";
import PriceTable from "../components/PriceTable.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  directoryCategories,
  directoryItemsFor,
  modelPriceRows,
  planRows,
  publishedDealRows,
} from "../lib/data";

const globalUsdRows = modelPriceRows.filter(
  (row) => row.provider.region === "global" && row.currency === "USD",
);
const featuredRows = [...globalUsdRows]
  .sort((a, b) => a.input + a.output - (b.input + b.output))
  .slice(0, 6);
const featuredPlanIds = [
  "chatgpt-free",
  "chatgpt-plus",
  "claude-free",
  "claude-pro",
  "gemini-free",
  "google-ai-pro",
];
const featuredPlans = featuredPlanIds
  .map((id) => planRows.find((plan) => plan.id === id))
  .filter((plan) => plan !== undefined);
const featuredDeals = publishedDealRows
  .filter((deal) => deal.featured && deal.status !== "ended")
  .sort((a, b) => (a.endsAt ?? "9999-12-31").localeCompare(b.endsAt ?? "9999-12-31"))
  .slice(0, 3);
const finderMeta = [
  { id: "chatgpt-plus", uses: ["chat", "office"], quality: 9, ease: 9, reason: "综合能力均衡，适合多数人的第一款付费 AI" },
  { id: "chatgpt-free", uses: ["chat", "office"], quality: 7, ease: 9, reason: "免费体验通用问答、写作和基础工具能力" },
  { id: "claude-free", uses: ["chat", "office"], quality: 7, ease: 8, reason: "免费体验长文写作、分析和基础代码能力" },
  { id: "gemini-free", uses: ["chat", "research", "office"], quality: 7, ease: 8, reason: "免费体验 Google 生态、多模态和研究能力" },
  { id: "claude-pro", uses: ["chat", "coding", "office"], quality: 9, ease: 8, reason: "长文写作、代码理解和复杂分析表现突出" },
  { id: "google-ai-pro", uses: ["chat", "research", "office"], quality: 9, ease: 8, reason: "适合 Google 生态、资料整理和多模态任务" },
  { id: "perplexity-pro", uses: ["research"], quality: 9, ease: 9, reason: "强调来源引用，适合查资料和研究报告" },
  { id: "perplexity-free", uses: ["research"], quality: 7, ease: 9, reason: "免费获得带来源的搜索回答和基础研究能力" },
  { id: "github-copilot-pro", uses: ["coding"], quality: 8, ease: 9, reason: "价格较低，适合日常 IDE 编程和 Agent 工作流" },
  { id: "github-copilot-free", uses: ["coding"], quality: 6, ease: 9, reason: "适合低频代码补全和初次体验 AI 编程" },
  { id: "baidu-comate-standard", uses: ["coding"], quality: 6, ease: 8, reason: "国内免费使用的代码补全与编程助手" },
  { id: "cursor-pro", uses: ["coding"], quality: 9, ease: 7, reason: "适合多文件修改、代码库理解和高频开发" },
  { id: "cursor-hobby", uses: ["coding"], quality: 7, ease: 7, reason: "免费体验 AI 原生编辑器和有限 Agent 能力" },
  { id: "midjourney-basic", uses: ["image"], quality: 9, ease: 7, reason: "适合高质量图片生成和视觉风格探索" },
  { id: "runway-standard", uses: ["video"], quality: 9, ease: 7, reason: "适合 AI 视频生成、编辑和持续创作" },
  { id: "runway-free", uses: ["video"], quality: 6, ease: 7, reason: "免费体验视频生成和基础创作工具" },
  { id: "suno-pro", uses: ["audio"], quality: 9, ease: 9, reason: "适合歌曲、配乐和高频音乐生成" },
  { id: "suno-free", uses: ["audio"], quality: 7, ease: 9, reason: "免费体验完整歌曲和音乐创作" },
  { id: "elevenlabs-free", uses: ["audio"], quality: 7, ease: 8, reason: "免费体验 AI 配音、语音生成和音频工具" },
  { id: "kimi-andante", uses: ["chat", "office"], quality: 8, ease: 9, reason: "中文体验友好，适合文档、写作和 Agent 任务" },
  { id: "kimi-moderato", uses: ["research"], quality: 8, ease: 9, reason: "适合中文深度研究、长文档和复杂任务" },
  { id: "kimi-adagio", uses: ["chat", "research", "office"], quality: 7, ease: 9, reason: "免费体验中文 Agent、文档和研究能力" },
  { id: "glm-coding-lite", uses: ["coding"], quality: 7, ease: 7, reason: "国内可用的轻量 AI 编程套餐" },
];
const finderCandidates = finderMeta
  .map((meta) => {
    const plan = planRows.find((item) => item.id === meta.id);
    return plan ? { plan, uses: meta.uses, quality: meta.quality, ease: meta.ease, reason: meta.reason } : undefined;
  })
  .filter((item) => item !== undefined);
---

<BaseLayout
  title="惠选AI | 帮你选到更适合的 AI"
  description="按用途、预算和偏好选择适合你的 AI 产品，并比较主流 AI 的订阅价格、使用额度和官方优惠。"
>
  <section class="hero shell">
    <div class="hero-copy">
      <p class="eyebrow">CHOOSE SMARTER · SPEND BETTER</p>
      <h1>选对 AI，<em>钱花得更值</em></h1>
      <p class="lead">
        告诉我们你想做什么、预算多少，先找到更适合的产品，再比较价格、额度和官方优惠。
      </p>
    </div>
    <div id="ai-finder"><AiFinder candidates={finderCandidates} /></div>
  </section>

  <section class="section shell" aria-labelledby="plan-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">MONTHLY PLANS</p>
        <h2 id="plan-heading">个人订阅套餐</h2>
        <p>先看每月实际支出，再比较使用额度和适合场景。</p>
      </div>
      <a href="/plans/">查看全部</a>
    </div>
    <div class="plan-grid">
      {featuredPlans.map((plan) => <PlanCard plan={plan} compact />)}
    </div>
  </section>

  <section id="directory" class="section shell">
    <div class="section-heading">
      <div>
        <p class="eyebrow">PRODUCT DIRECTORY</p>
        <h2>AI 产品导航</h2>
        <p>按用途整理主流模型、智能体（Agent）、自动化、搜索、编程以及图片和视频工具。</p>
      </div>
    </div>
    {
      directoryCategories.map((category) => {
        const items = directoryItemsFor(category.id);
        return (
          <section class="directory-section" aria-labelledby={`directory-${category.id}`}>
            <div class="directory-heading">
              <div>
                <h3 id={`directory-${category.id}`}>{category.name}</h3>
                <p>{category.description}</p>
              </div>
              <a href={`/directory/${category.id}/`}>查看更多</a>
            </div>
            <div class="directory-grid">
              {items.slice(0, 6).map((item) => <DirectoryCard item={item} />)}
            </div>
          </section>
        );
      })
    }
  </section>

  <section id="deals" class="section shell">
    <div class="section-heading">
      <div>
        <p class="eyebrow">DEAL WATCH</p>
        <h2>优惠情报</h2>
        <p>经过人工核实的官方折扣、赠送额度和免费试用，临近结束的活动优先展示。</p>
      </div>
      <a href="/deals/">查看全部</a>
    </div>
    <div class="deal-grid">
      {featuredDeals.map((deal) => <DealCard deal={deal} compact />)}
    </div>
  </section>

  <script>
    const expiredDealCards = document.querySelectorAll<HTMLElement>(".deal-card[data-deal-end]");
    const now = Date.now();
    expiredDealCards.forEach((card) => {
      const endDate = card.dataset.dealEnd;
      if (!endDate) return;
      const chinaDayEnd = Date.parse(`${endDate}T23:59:59+08:00`);
      if (Number.isFinite(chinaDayEnd) && now > chinaDayEnd) card.remove();
    });
  </script>

  <section class="section shell" aria-labelledby="api-price-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">FOR DEVELOPERS</p>
        <h2 id="api-price-heading">开发者 API 价格</h2>
        <p>用于程序调用的按量计费，与 ChatGPT、Claude、Gemini 个人订阅相互独立。</p>
      </div>
      <a href="/models/">查看全部</a>
    </div>
    <PriceTable rows={featuredRows} compact />
  </section>

</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    min-height: 0;
    gap: 48px;
    padding-block: 84px 70px;
  }

  .hero-copy {
    width: 100%;
  }

  #ai-finder {
    width: 100%;
  }

  .eyebrow {
    margin: 0 0 15px;
    color: var(--cyan);
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 12px;
    font-weight: 800;
  }

  h1 {
    max-width: none;
    margin: 0;
    color: var(--text);
    font-size: clamp(48px, 6vw, 78px);
    line-height: 1.08;
    letter-spacing: 0;
    white-space: nowrap;
  }

  h1 em {
    color: var(--cyan);
    font-style: normal;
    text-shadow: 0 0 35px rgba(103, 232, 249, 0.22);
  }

  .lead {
    max-width: none;
    margin: 25px 0 0;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.8;
    white-space: nowrap;
  }

  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 14px var(--green);
  }

  .deal-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .plan-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  @media (max-width: 900px) {
    .plan-grid,
    .deal-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .plan-grid,
    .deal-grid {
      grid-template-columns: 1fr;
    }
  }

  .section {
    padding-block: 62px;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: 30px;
  }

  .section-heading div > p:last-child {
    margin: 9px 0 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .section-heading > a {
    flex: 0 0 auto;
    color: var(--cyan);
    font-size: 14px;
    font-weight: 800;
  }

  .directory-section {
    padding-block: 32px;
    border-top: 1px solid var(--line);
  }

  .directory-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 18px;
  }

  .directory-heading h3 {
    margin: 0;
    font-size: 20px;
  }

  .directory-heading p {
    max-width: 760px;
    margin: 7px 0 0;
    color: var(--muted);
    font-size: 12px;
    line-height: 1.6;
  }

  .directory-heading a {
    flex: 0 0 auto;
    color: var(--cyan);
    font-size: 12px;
    font-weight: 800;
  }

  .directory-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .empty-band {
    display: flex;
    align-items: center;
    gap: 18px;
    border-block: 1px solid var(--line);
    padding: 30px 4px;
  }

  .pulse {
    flex: 0 0 auto;
  }

  .empty-band strong {
    font-size: 16px;
  }

  .empty-band p {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  @media (max-width: 820px) {
    .hero {
      gap: 44px;
      padding-block: 64px 45px;
    }

    h1 {
      font-size: 48px;
      white-space: normal;
    }

    h1 em {
      display: block;
    }

    .lead {
      white-space: normal;
    }

    .section-heading {
      align-items: start;
    }

    .directory-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    h1 {
      font-size: 40px;
    }

    .lead {
      font-size: 15px;
    }

    .section {
      padding-block: 45px;
    }

    .directory-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
