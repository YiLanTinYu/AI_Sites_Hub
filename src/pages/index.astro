---
import DirectoryCard from "../components/DirectoryCard.astro";
import DealCard from "../components/DealCard.astro";
import PriceTable from "../components/PriceTable.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  directoryCategories,
  directoryItemsFor,
  latestVerifiedAt,
  modelPriceRows,
  publishedDealRows,
  providers,
} from "../lib/data";

const globalUsdRows = modelPriceRows.filter(
  (row) => row.provider.region === "global" && row.currency === "USD",
);
const featuredRows = [...globalUsdRows]
  .sort((a, b) => a.input + a.output - (b.input + b.output))
  .slice(0, 6);
const chinaRows = modelPriceRows
  .filter((row) => row.provider.region === "china" && row.currency === "CNY")
  .sort((a, b) => a.input + a.output - (b.input + b.output))
  .slice(0, 6);

const lowestInput = featuredRows[0];
const lowestOutput = [...globalUsdRows].sort((a, b) => a.output - b.output)[0];
const featuredDeals = publishedDealRows
  .filter((deal) => deal.featured && deal.status !== "ended")
  .sort((a, b) => (a.endsAt ?? "9999-12-31").localeCompare(b.endsAt ?? "9999-12-31"))
  .slice(0, 3);
---

<BaseLayout
  title="AI 模型比价与优惠发现 | AI Sites Hub"
  description="比较国内外主流 AI 模型开发接口价格、重复内容优惠、单次处理量与活动，计算真实使用成本。"
>
  <section class="hero shell">
    <div class="hero-copy">
      <p class="eyebrow">AI MODEL PRICE INTELLIGENCE</p>
      <h1>AI 模型价格，<br /><em>看清再选择</em></h1>
      <p class="lead">
        统一比较发送内容、生成内容和重复内容的价格，追踪官方优惠与价格变化。每条数据都保留官方来源和最近确认时间。
      </p>
      <div class="hero-actions">
        <a class="primary-button" href="/models/">
          查看完整价格
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
        <span>价格最近确认于 {latestVerifiedAt}</span>
      </div>
    </div>
    <div class="signal-panel" aria-label="数据概览">
      <div class="signal-head">
        <span>PRICE SIGNAL</span>
        <i></i>
      </div>
      <div class="signal-grid">
        <article>
          <span>已确认价格的模型</span>
          <strong>{modelPriceRows.length}</strong>
        </article>
        <article>
          <span>官方厂商</span>
          <strong>{providers.length}</strong>
        </article>
        <article class="wide">
          <span>最低输入价格</span>
          <strong>${lowestInput.input}<small> / 100 万个文本单位</small></strong>
          <p>{lowestInput.name}</p>
        </article>
        <article class="wide">
          <span>最低输出价格</span>
          <strong>${lowestOutput.output}<small> / 100 万个文本单位</small></strong>
          <p>{lowestOutput.name}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section shell" aria-labelledby="price-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">VERIFIED API PRICING</p>
        <h2 id="price-heading">高性价比模型</h2>
        <p>按“发送内容价格 + 生成内容价格”从低到高排序，单位为美元/100 万个文本单位。</p>
      </div>
      <a href="/models/">查看全部</a>
    </div>
    <PriceTable rows={featuredRows} compact />
  </section>

  <section class="section shell" aria-labelledby="china-price-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">CHINA API PRICING</p>
        <h2 id="china-price-heading">国内模型价格</h2>
        <p>展示国内厂商人民币开发接口价格，单位为人民币/100 万个文本单位，不与美元价格混合排序。</p>
      </div>
      <a href="/models/">查看全部</a>
    </div>
    <PriceTable rows={chinaRows} compact />
  </section>

  <section id="deals" class="section shell">
    <div class="section-heading">
      <div>
        <p class="eyebrow">DEAL WATCH</p>
        <h2>优惠情报</h2>
        <p>经过人工核实的官方折扣、赠送额度和免费试用，临近结束的活动优先展示。</p>
      </div>
      <a href="/deals/">查看全部</a>
    </div>
    <div class="deal-grid">
      {featuredDeals.map((deal) => <DealCard deal={deal} compact />)}
    </div>
  </section>

  <section id="directory" class="section shell">
    <div class="section-heading">
      <div>
        <p class="eyebrow">PRODUCT DIRECTORY</p>
        <h2>AI 产品导航</h2>
        <p>按用途整理主流模型、智能体（Agent）、自动化、搜索、编程以及图片和视频工具。</p>
      </div>
    </div>
    {
      directoryCategories.map((category) => {
        const items = directoryItemsFor(category.id);
        return (
          <section class="directory-section" aria-labelledby={`directory-${category.id}`}>
            <div class="directory-heading">
              <div>
                <h3 id={`directory-${category.id}`}>{category.name}</h3>
                <p>{category.description}</p>
              </div>
              <a href={`/directory/${category.id}/`}>查看更多</a>
            </div>
            <div class="directory-grid">
              {items.slice(0, 6).map((item) => <DirectoryCard item={item} />)}
            </div>
          </section>
        );
      })
    }
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    align-items: center;
    min-height: 620px;
    gap: 64px;
    padding-block: 84px 70px;
  }

  .eyebrow {
    margin: 0 0 15px;
    color: var(--cyan);
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 12px;
    font-weight: 800;
  }

  h1 {
    max-width: 700px;
    margin: 0;
    color: var(--text);
    font-size: clamp(48px, 6vw, 78px);
    line-height: 1.08;
    letter-spacing: 0;
  }

  h1 em {
    color: var(--cyan);
    font-style: normal;
    text-shadow: 0 0 35px rgba(103, 232, 249, 0.22);
  }

  .lead {
    max-width: 630px;
    margin: 25px 0 0;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 34px;
  }

  .hero-actions > span {
    color: var(--muted);
    font-size: 12px;
  }

  .primary-button {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border-radius: 6px;
    padding: 13px 17px;
    background: var(--cyan);
    color: #031018;
    font-size: 14px;
    font-weight: 900;
  }

  .primary-button:hover {
    background: #a5f3fc;
  }

  .primary-button svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .signal-panel {
    border: 1px solid rgba(103, 232, 249, 0.26);
    border-radius: 8px;
    padding: 18px;
    background: rgba(10, 18, 32, 0.78);
    box-shadow: var(--shadow), inset 0 0 50px rgba(103, 232, 249, 0.025);
  }

  .signal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
    padding: 0 2px 14px;
    color: var(--muted);
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 11px;
    font-weight: 800;
  }

  .signal-head i,
  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 14px var(--green);
  }

  .signal-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    margin-top: 1px;
    background: var(--line);
  }

  .deal-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .signal-grid article {
    min-height: 125px;
    padding: 20px;
    background: #0a1220;
  }

  @media (max-width: 900px) {
    .deal-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .deal-grid {
      grid-template-columns: 1fr;
    }
  }

  .signal-grid .wide {
    min-height: 136px;
  }

  .signal-grid span {
    color: var(--muted);
    font-size: 12px;
  }

  .signal-grid strong {
    display: block;
    margin-top: 10px;
    color: var(--text);
    font-size: 30px;
  }

  .signal-grid small {
    color: var(--muted);
    font-size: 11px;
  }

  .signal-grid p {
    margin: 8px 0 0;
    color: var(--cyan);
    font-size: 12px;
  }

  .section {
    padding-block: 62px;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: 30px;
  }

  .section-heading div > p:last-child {
    margin: 9px 0 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .section-heading > a {
    flex: 0 0 auto;
    color: var(--cyan);
    font-size: 14px;
    font-weight: 800;
  }

  .directory-section {
    padding-block: 32px;
    border-top: 1px solid var(--line);
  }

  .directory-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 18px;
  }

  .directory-heading h3 {
    margin: 0;
    font-size: 20px;
  }

  .directory-heading p {
    max-width: 760px;
    margin: 7px 0 0;
    color: var(--muted);
    font-size: 12px;
    line-height: 1.6;
  }

  .directory-heading a {
    flex: 0 0 auto;
    color: var(--cyan);
    font-size: 12px;
    font-weight: 800;
  }

  .directory-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .empty-band {
    display: flex;
    align-items: center;
    gap: 18px;
    border-block: 1px solid var(--line);
    padding: 30px 4px;
  }

  .pulse {
    flex: 0 0 auto;
  }

  .empty-band strong {
    font-size: 16px;
  }

  .empty-band p {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      gap: 44px;
      padding-block: 64px 45px;
    }

    h1 {
      font-size: 48px;
    }

    .section-heading {
      align-items: start;
    }

    .directory-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .hero-actions {
      align-items: start;
      flex-direction: column;
    }

    h1 {
      font-size: 40px;
    }

    .lead {
      font-size: 15px;
    }

    .signal-grid {
      grid-template-columns: 1fr;
    }

    .section {
      padding-block: 45px;
    }

    .directory-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
